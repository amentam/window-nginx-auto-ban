# ========== 服务器配置 ==========
NODE_ENV=production
BAN_PORT=3001

# ========== Nginx 日志路径 ==========
NGINX_LOG_PATH=C:/nginx/logs/

# ========== 封禁配置 ==========
BAN_THRESHOLD=30              # 1分钟内超过30次50x错误就封禁
SCAN_INTERVAL=60              # 扫描间隔（秒）
REAL_TIME_MONITORING=true     # 实时监控
AUTO_UNBAN_HOURS=0            # 自动解封时间（小时），0表示不自动解封
AUTO_UNBAN_SUBNET=false       # 是否允许自动解封 /24 子网封禁（建议设为 false）
# ========== 黑名单文件 ==========
BANNED_FILE=C:/nginx/banned_ips.json

# ========== IP 白名单（逗号分隔）==========
WHITELIST=127.0.0.1

# ========== SMTP 邮件配置 ==========
SMTP_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
ALERT_EMAIL=admin@yourdomain.com

# ========== Web 管理界面 ==========
WEB_ENABLED=true
WEB_PORT=3001
WEB_USERNAME=admin
WEB_PASSWORD=your-secure-password

# ========== 调试模式 ==========
DEBUG=false